# Copie para .env.docker na raiz (opcional) — usado pelo docker-compose
# Não commitar .env.docker com senhas reais em ambientes compartilhados.

POSTGRES_USER=floricultura
POSTGRES_PASSWORD=floricultura_dev_local
POSTGRES_DB=floricultura_dev
POSTGRES_PORT=54332

# URL para ferramentas externas (DBeaver, psql). Não é usada pelo Next.js diretamente.
DATABASE_URL=postgresql://floricultura:floricultura_dev_local@localhost:54332/floricultura_dev
