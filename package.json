{
  "name": "flordoestudante",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo Flor do Estudante — floricultura-web e home-decor-web",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter floricultura-web run dev",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean --parallel"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.14.2"
}
